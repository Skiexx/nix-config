# =============================================================================
# КОНФИГУРАЦИЯ AMD GPU
# =============================================================================
# RADV (Vulkan) включен по умолчанию через mesa.
# VA-API обеспечивает аппаратное декодирование видео.
# =============================================================================
{
  config,
  lib,
  pkgs,
  ...
}: {
  services.xserver.videoDrivers = ["amdgpu"];

  hardware.graphics = {
    enable = true;
    enable32Bit = true;
    extraPackages = with pkgs; [
      libva          # VA-API (аппаратное декодирование видео)
      libvdpau-va-gl # VDPAU через VA-API
    ];
  };
}
