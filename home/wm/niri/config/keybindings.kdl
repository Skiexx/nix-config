binds {

    // =========================
    //  Запуск приложений
    // =========================
    Mod+Return hotkey-overlay-title="Терминал (Ghostty)" { spawn "ghostty"; }
    Mod+D hotkey-overlay-title="Лаунчер (DMS Spotlight)" { spawn "dms" "ipc" "call" "spotlight" "toggle"; }
    Mod+B hotkey-overlay-title="Браузер (Vivaldi)" { spawn "vivaldi"; }
    Mod+E hotkey-overlay-title="File Manager (Nemo)" { spawn "nemo"; }
    Mod+Space hotkey-overlay-title="Switch Layout (US/RU)" { switch-layout "next"; }

    Super+Alt+L hotkey-overlay-title="Блокировка экрана" { spawn "dms" "ipc" "call" "lock" "lock"; }

    Mod+Shift+Slash hotkey-overlay-title="Показать хоткеи" { show-hotkey-overlay; }

    // =========================
    //  Звук и медиа
    // =========================
    XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title="Громкость +" { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1+ -l 1.0"; }
    XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title="Громкость -" { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.1-"; }
    XF86AudioMute        allow-when-locked=true hotkey-overlay-title="Без звука" { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true hotkey-overlay-title="Микрофон вкл/выкл" { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }
    XF86AudioPlay        allow-when-locked=true hotkey-overlay-title="Плей/Пауза" { spawn-sh "playerctl play-pause"; }
    XF86AudioStop        allow-when-locked=true hotkey-overlay-title="Стоп" { spawn-sh "playerctl stop"; }
    XF86AudioPrev        allow-when-locked=true hotkey-overlay-title="Предыдущий трек" { spawn-sh "playerctl previous"; }
    XF86AudioNext        allow-when-locked=true hotkey-overlay-title="Следующий трек" { spawn-sh "playerctl next"; }

    // =========================
    //  Яркость
    // =========================
    XF86MonBrightnessUp hotkey-overlay-title="Яркость +" allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown hotkey-overlay-title="Яркость -" allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // =========================
    //  Управление окнами
    // =========================
    Mod+O repeat=false hotkey-overlay-title="Обзор окон" { toggle-overview; }
    Mod+Q repeat=false hotkey-overlay-title="Закрыть окно" { close-window; }

    // Фокус
    Mod+Left  hotkey-overlay-title="Фокус влево" { focus-column-left; }
    Mod+Down  hotkey-overlay-title="Фокус вниз" { focus-window-down; }
    Mod+Up    hotkey-overlay-title="Фокус вверх" { focus-window-up; }
    Mod+Right hotkey-overlay-title="Фокус вправо" { focus-column-right; }
    Mod+H     hotkey-overlay-title="Фокус влево (vim)" { focus-column-left; }
    Mod+J     hotkey-overlay-title="Фокус вниз (vim)" { focus-window-down; }
    Mod+K     hotkey-overlay-title="Фокус вверх (vim)" { focus-window-up; }
    Mod+L     hotkey-overlay-title="Фокус вправо (vim)" { focus-column-right; }

    // Перемещение колонок/окон
    Mod+Ctrl+Left  hotkey-overlay-title="Переместить влево" { move-column-left; }
    Mod+Ctrl+Down  hotkey-overlay-title="Переместить вниз" { move-window-down; }
    Mod+Ctrl+Up    hotkey-overlay-title="Переместить вверх" { move-window-up; }
    Mod+Ctrl+Right hotkey-overlay-title="Переместить вправо" { move-column-right; }
    Mod+Ctrl+H     hotkey-overlay-title="Переместить влево (vim)" { move-column-left; }
    Mod+Ctrl+J     hotkey-overlay-title="Переместить вниз (vim)" { move-window-down; }
    Mod+Ctrl+K     hotkey-overlay-title="Переместить вверх (vim)" { move-window-up; }
    Mod+Ctrl+L     hotkey-overlay-title="Переместить вправо (vim)" { move-column-right; }

    // Начало/Конец
    Mod+Home hotkey-overlay-title="Первая колонка" { focus-column-first; }
    Mod+End  hotkey-overlay-title="Последняя колонка" { focus-column-last; }
    Mod+Ctrl+Home hotkey-overlay-title="В начало" { move-column-to-first; }
    Mod+Ctrl+End  hotkey-overlay-title="В конец" { move-column-to-last; }

    // Мониторы
    Mod+Shift+Left  hotkey-overlay-title="Монитор слева" { focus-monitor-left; }
    Mod+Shift+Down  hotkey-overlay-title="Монитор снизу" { focus-monitor-down; }
    Mod+Shift+Up    hotkey-overlay-title="Монитор сверху" { focus-monitor-up; }
    Mod+Shift+Right hotkey-overlay-title="Монитор справа" { focus-monitor-right; }
    Mod+Shift+H     hotkey-overlay-title="Монитор слева (vim)" { focus-monitor-left; }
    Mod+Shift+J     hotkey-overlay-title="Монитор снизу (vim)" { focus-monitor-down; }
    Mod+Shift+K     hotkey-overlay-title="Монитор сверху (vim)" { focus-monitor-up; }
    Mod+Shift+L     hotkey-overlay-title="Монитор справа (vim)" { focus-monitor-right; }

    Mod+Shift+Ctrl+Left  hotkey-overlay-title="Окно на монитор слева" { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down  hotkey-overlay-title="Окно на монитор снизу" { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up    hotkey-overlay-title="Окно на монитор сверху" { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right hotkey-overlay-title="Окно на монитор справа" { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+H     hotkey-overlay-title="Окно на монитор слева (vim)" { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J     hotkey-overlay-title="Окно на монитор снизу (vim)" { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K     hotkey-overlay-title="Окно на монитор сверху (vim)" { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L     hotkey-overlay-title="Окно на монитор справа (vim)" { move-column-to-monitor-right; }

    // Рабочие пространства
    Mod+Page_Down      hotkey-overlay-title="Следующее пространство" { focus-workspace-down; }
    Mod+Page_Up        hotkey-overlay-title="Предыдущее пространство" { focus-workspace-up; }
    Mod+U              hotkey-overlay-title="Пространство вниз" { focus-workspace-down; }
    Mod+I              hotkey-overlay-title="Пространство вверх" { focus-workspace-up; }
    Mod+Ctrl+Page_Down hotkey-overlay-title="Окно в след. пространство" { move-column-to-workspace-down; }
    Mod+Ctrl+Page_Up   hotkey-overlay-title="Окно в пред. пространство" { move-column-to-workspace-up; }
    Mod+Ctrl+U         hotkey-overlay-title="Окно в пространство вниз" { move-column-to-workspace-down; }
    Mod+Ctrl+I         hotkey-overlay-title="Окно в пространство вверх" { move-column-to-workspace-up; }
    Mod+Shift+Page_Down hotkey-overlay-title="Сдвинуть пространство вниз" { move-workspace-down; }
    Mod+Shift+Page_Up   hotkey-overlay-title="Сдвинуть пространство вверх" { move-workspace-up; }
    Mod+Shift+U         hotkey-overlay-title="Сдвинуть пространство вниз" { move-workspace-down; }
    Mod+Shift+I         hotkey-overlay-title="Сдвинуть пространство вверх" { move-workspace-up; }

    // Мышь
    Mod+WheelScrollDown      cooldown-ms=150 hotkey-overlay-title="Колесо: пространство вниз" { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 hotkey-overlay-title="Колесо: пространство вверх" { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 { move-column-to-workspace-up; }
    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }
    Mod+Ctrl+WheelScrollRight { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  { move-column-left; }
    Mod+Shift+WheelScrollDown      { focus-column-right; }
    Mod+Shift+WheelScrollUp        { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   { move-column-left; }

    // Рабочие пространства по номеру
    Mod+1 hotkey-overlay-title="Пространство 1" { focus-workspace 1; }
    Mod+2 hotkey-overlay-title="Пространство 2" { focus-workspace 2; }
    Mod+3 hotkey-overlay-title="Пространство 3" { focus-workspace 3; }
    Mod+4 hotkey-overlay-title="Пространство 4" { focus-workspace 4; }
    Mod+5 hotkey-overlay-title="Пространство 5" { focus-workspace 5; }
    Mod+6 hotkey-overlay-title="Пространство 6" { focus-workspace 6; }
    Mod+7 hotkey-overlay-title="Пространство 7" { focus-workspace 7; }
    Mod+8 hotkey-overlay-title="Пространство 8" { focus-workspace 8; }
    Mod+9 hotkey-overlay-title="Пространство 9" { focus-workspace 9; }
    Mod+Ctrl+1 hotkey-overlay-title="Окно в пространство 1" { move-column-to-workspace 1; }
    Mod+Ctrl+2 hotkey-overlay-title="Окно в пространство 2" { move-column-to-workspace 2; }
    Mod+Ctrl+3 hotkey-overlay-title="Окно в пространство 3" { move-column-to-workspace 3; }
    Mod+Ctrl+4 hotkey-overlay-title="Окно в пространство 4" { move-column-to-workspace 4; }
    Mod+Ctrl+5 hotkey-overlay-title="Окно в пространство 5" { move-column-to-workspace 5; }
    Mod+Ctrl+6 hotkey-overlay-title="Окно в пространство 6" { move-column-to-workspace 6; }
    Mod+Ctrl+7 hotkey-overlay-title="Окно в пространство 7" { move-column-to-workspace 7; }
    Mod+Ctrl+8 hotkey-overlay-title="Окно в пространство 8" { move-column-to-workspace 8; }
    Mod+Ctrl+9 hotkey-overlay-title="Окно в пространство 9" { move-column-to-workspace 9; }

    // Действия с окнами
    Mod+BracketLeft  hotkey-overlay-title="Забрать окно слева" { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title="Забрать окно справа" { consume-or-expel-window-right; }
    Mod+Comma  hotkey-overlay-title="Поглотить окно в колонку" { consume-window-into-column; }
    Mod+Period hotkey-overlay-title="Вытолкнуть окно из колонки" { expel-window-from-column; }
    Mod+R hotkey-overlay-title="Переключить ширину колонки" { switch-preset-column-width; }
    Mod+Shift+R hotkey-overlay-title="Переключить высоту окна" { switch-preset-window-height; }
    Mod+Ctrl+R hotkey-overlay-title="Сбросить высоту окна" { reset-window-height; }
    Mod+F hotkey-overlay-title="Развернуть колонку" { maximize-column; }
    Mod+Shift+F hotkey-overlay-title="Полноэкранный режим" { fullscreen-window; }
    Mod+M hotkey-overlay-title="Развернуть до краёв" { maximize-window-to-edges; }
    Mod+Ctrl+F hotkey-overlay-title="Расширить на свободное место" { expand-column-to-available-width; }
    Mod+C hotkey-overlay-title="Центрировать колонку" { center-column; }
    Mod+Ctrl+C hotkey-overlay-title="Центрировать видимые" { center-visible-columns; }
    Mod+Minus hotkey-overlay-title="Уменьшить ширину (-10%)" { set-column-width "-10%"; }
    Mod+Equal hotkey-overlay-title="Увеличить ширину (+10%)" { set-column-width "+10%"; }
    Mod+Shift+Minus hotkey-overlay-title="Уменьшить высоту (-10%)" { set-window-height "-10%"; }
    Mod+Shift+Equal hotkey-overlay-title="Увеличить высоту (+10%)" { set-window-height "+10%"; }
    Mod+V       hotkey-overlay-title="Плавающее окно" { toggle-window-floating; }
    Mod+Shift+V hotkey-overlay-title="Фокус: плав./тайлинг" { switch-focus-between-floating-and-tiling; }
    Mod+W hotkey-overlay-title="Вкладки в колонке" { toggle-column-tabbed-display; }

    // Скриншоты
    Print hotkey-overlay-title="Скриншот (область)" { screenshot; }
    Ctrl+Print hotkey-overlay-title="Скриншот (экран)" { screenshot-screen; }
    Mod+X hotkey-overlay-title="Скриншот (окно)" { screenshot-window; }

    // Клавиатура
    Mod+Escape allow-inhibiting=false hotkey-overlay-title="Переключить захват клавиш" { toggle-keyboard-shortcuts-inhibit; }

    // Питание и выход
    Mod+Shift+Delete hotkey-overlay-title="Меню питания" { spawn "dms" "ipc" "call" "powermenu" "toggle"; }
    Mod+Shift+E hotkey-overlay-title="Выйти из Niri" { quit; }
    Ctrl+Alt+Delete hotkey-overlay-title="Выйти из Niri" { quit; }
    Mod+Shift+P hotkey-overlay-title="Выключить мониторы" { power-off-monitors; }
}
