# =============================================================================
# ПОЛЬЗОВАТЕЛЬСКИЕ СЛУЖБЫ
# =============================================================================
# Systemd-службы пользовательского уровня (запускаются при логине, не при загрузке)
# Управление: systemctl --user {start|stop|status} <служба>
# =============================================================================
{
  services = {
    # --- GPG-агент ---
    # Кэширует пароли GPG-ключей, заменяет ssh-agent (поддержка Yubikey)
    gpg-agent = {
      enable = true;
      
      # GPG-ключи используются для SSH-аутентификации
      enableSshSupport = true;
    };
    
    # --- Дополнительные службы (раскомментировать по необходимости) ---
    # syncthing.enable = true;
    # mbsync.enable = true;
  };
}
