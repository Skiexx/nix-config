# =============================================================================
# КОНФИГУРАЦИЯ GTK-ТЕМЫ
# =============================================================================
# Пользовательская GTK-тема для единообразного вида приложений
#
# ИСПОЛЬЗУЕМЫЕ ТЕМЫ:
# - GTK-тема: Juno-ocean (тёмная)
# - Иконки: BeautyLine (современный набор)
#
# ПРИМЕНЯЕТСЯ К:
# - Всем GTK3 и GTK4 приложениям
# - Файловым менеджерам (Nemo, Nautilus)
# - Системным диалогам
# - Electron-приложениям с поддержкой GTK
#
# ТЁМНЫЙ РЕЖИМ:
# - Принудительно через gtk-application-prefer-dark-theme
# - Импорт CSS тёмного варианта для GTK4
#
# ТЕСТИРОВАНИЕ ТЕМ:
# - Предпросмотр: gtk3-demo или gtk4-demo
# - Каталог тем: https://www.gnome-look.org/
# =============================================================================
{ pkgs, lib, isDarwin ? false, ... }: {
  gtk = lib.mkIf (!isDarwin) rec {
    # Включить управление GTK-темой через Home Manager
    enable = true;

    # ---------------------------------------------------------------------------
    # ИКОНКИ
    # ---------------------------------------------------------------------------
    # BeautyLine: яркий современный набор иконок
    iconTheme = {
      name = "BeautyLine";
      package = pkgs.beauty-line-icon-theme;
    };
    
    # ---------------------------------------------------------------------------
    # GTK-ТЕМА
    # ---------------------------------------------------------------------------
    # Juno: современная тема с вариантом ocean (GTK3/GTK4)
    theme = {
      name = "Juno-ocean";
      package = pkgs.juno-theme;
    };
    
    # ---------------------------------------------------------------------------
    # НАСТРОЙКИ GTK4
    # ---------------------------------------------------------------------------
    gtk4 = {
      theme = null;
      # Принудительно тёмная тема
      extraConfig = {
        gtk-application-prefer-dark-theme = true;
      };

      # Импорт тёмного CSS (некоторые темы не применяют его автоматически)
      extraCss = ''
        @import url("file://${theme.package}/share/themes/${theme.name}/gtk-4.0/gtk-dark.css");
      '';
    };
    
    # ---------------------------------------------------------------------------
    # ДОПОЛНИТЕЛЬНЫЕ ПАРАМЕТРЫ
    # ---------------------------------------------------------------------------
    # Раскомментировать для расширенной настройки:
    #
    # gtk3.extraConfig:
    #   gtk-application-prefer-dark-theme = true
    #   gtk-cursor-theme-name = "Adwaita"
    #   gtk-cursor-theme-size = 24
    #
    # gtk3.extraCss:
    #   Пользовательские CSS-правила для GTK3
    #
    # Шрифты:
    #   font.name = "Sans";
    #   font.size = 11;
    # ---------------------------------------------------------------------------
  };
}
